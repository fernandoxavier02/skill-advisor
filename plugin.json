{
  "name": "skill-advisor",
  "description": "Intelligent toolchain orchestrator for Claude Code — recommends skills, plugins, MCPs, and agents for any task with dependency-aware ordering",
  "version": "0.1.0",
  "author": {
    "name": "fernandoxavier02",
    "url": "https://github.com/fernandoxavier02"
  },
  "commands": [
    "./commands/advisor.md",
    "./commands/advisor-index.md",
    "./commands/advisor-config.md"
  ],
  "skills": [
    "./skills/advisor-skill"
  ],
  "agents": [
    "./agents/advisor-router.md"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/advisor-nudge.cjs"
          }
        ]
      }
    ]
  },
  "homepage": "https://github.com/fernandoxavier02/skill-advisor",
  "repository": "https://github.com/fernandoxavier02/skill-advisor",
  "license": "MIT",
  "keywords": [
    "skill-advisor",
    "routing",
    "orchestration",
    "skill-discovery",
    "mcp",
    "plugins",
    "claude-code"
  ]
}
